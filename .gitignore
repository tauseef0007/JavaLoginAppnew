cd ~/JavaLoginPracticeApp
 
cat > .gitignore << 'EOF'
target/              # Maven build output
*.jar                # Java archives
*.war                # Web archives
minikube-linux-amd64 # Minikube binary (128MB!)
bfg-*.jar            # BFG tool
.DS_Store            # Mac files
*.class              # Compiled Java
EOF
